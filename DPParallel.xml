<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite" data-provider-thread-count="2">
    <listeners>
        <listener class-name="listeners.TestListener"></listener>
    </listeners>
    <test verbose="2" preserve-order="true"
          name="parallel test" >
        <classes>
            <class name="tests.DataProviderParallel">
                <methods>
                    <include name="ValidatePositiveFlow"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>